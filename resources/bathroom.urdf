<?xml version="1.0" ?>
<!-- Test scene: Bathroom -->
<!-- Almost entirely mesh-less (box/cylinder/sphere primitives) -->
<!-- Purpose: stress-testing link-name-to-semantic-class matching -->
<robot name="bathroom">

  <link name="apartment_root">
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </link>

  <joint name="bathroom_furniture_base_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="apartment_root"/>
    <child link="bathroom_furniture_root"/>
  </joint>
  <link name="bathroom_furniture_root"/>

  <!-- ============================================================ -->
  <!-- BATHTUB (mesh-less)                                          -->
  <!-- ============================================================ -->
  <joint name="bathtub_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.5 0.9 0.0"/>
    <parent link="bathroom_furniture_root"/>
    <child link="bathtub"/>
  </joint>
  <link name="bathtub">
    <!-- Outer shell -->
    <visual>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.27"/>
      <geometry>
        <box size="0.75 1.7 0.54"/>
      </geometry>
      <material name="bathtub_white">
        <color rgba="0.95 0.95 0.95 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.27"/>
      <geometry>
        <box size="0.75 1.7 0.54"/>
      </geometry>
    </collision>
  </link>

  <!-- Bathtub faucet (revolute, mesh-less) -->
  <joint name="bathtub_faucet_joint" type="revolute">
    <origin rpy="0 0 0" xyz="0.0 -0.75 0.48"/>
    <parent link="bathtub"/>
    <child link="bathtub_faucet"/>
    <axis xyz="0 0 1"/>
    <limit effort="100.0" lower="-1.5708" upper="1.5708" velocity="1.0"/>
  </joint>
  <link name="bathtub_faucet">
    <visual>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.1"/>
      <geometry>
        <cylinder length="0.2" radius="0.025"/>
      </geometry>
      <material name="chrome">
        <color rgba="0.8 0.8 0.85 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.1"/>
      <geometry>
        <cylinder length="0.2" radius="0.025"/>
      </geometry>
    </collision>
  </link>

  <!-- Bathtub hot water handle (revolute) -->
  <joint name="bathtub_hot_water_handle_joint" type="revolute">
    <origin rpy="0 0 0" xyz="0.1 -0.73 0.42"/>
    <parent link="bathtub"/>
    <child link="bathtub_hot_water_handle"/>
    <axis xyz="1 0 0"/>
    <limit effort="50.0" lower="0.0" upper="3.14" velocity="1.0"/>
  </joint>
  <link name="bathtub_hot_water_handle">
    <visual>
      <geometry>
        <cylinder length="0.06" radius="0.03"/>
      </geometry>
      <material name="chrome"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.06" radius="0.03"/>
      </geometry>
    </collision>
  </link>

  <!-- Bathtub cold water handle (revolute) -->
  <joint name="bathtub_cold_water_handle_joint" type="revolute">
    <origin rpy="0 0 0" xyz="-0.1 -0.73 0.42"/>
    <parent link="bathtub"/>
    <child link="bathtub_cold_water_handle"/>
    <axis xyz="1 0 0"/>
    <limit effort="50.0" lower="0.0" upper="3.14" velocity="1.0"/>
  </joint>
  <link name="bathtub_cold_water_handle">
    <visual>
      <geometry>
        <cylinder length="0.06" radius="0.03"/>
      </geometry>
      <material name="chrome"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.06" radius="0.03"/>
      </geometry>
    </collision>
  </link>

  <!-- ============================================================ -->
  <!-- TOILET (mesh-less)                                           -->
  <!-- ============================================================ -->
  <joint name="toilet_joint" type="fixed">
    <origin rpy="0 0 0" xyz="2.3 0.4 0.0"/>
    <parent link="bathroom_furniture_root"/>
    <child link="toilet"/>
  </joint>
  <link name="toilet">
    <!-- Bowl base -->
    <visual>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.2"/>
      <geometry>
        <box size="0.38 0.6 0.40"/>
      </geometry>
      <material name="toilet_white">
        <color rgba="0.97 0.97 0.97 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.2"/>
      <geometry>
        <box size="0.38 0.6 0.40"/>
      </geometry>
    </collision>
    <!-- Tank -->
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.27 0.6"/>
      <geometry>
        <box size="0.36 0.18 0.35"/>
      </geometry>
    </collision>
  </link>

  <!-- Toilet lid (revolute) -->
  <joint name="toilet_lid_joint" type="revolute">
    <origin rpy="0 0 0" xyz="0.0 0.2 0.42"/>
    <parent link="toilet"/>
    <child link="toilet_lid"/>
    <axis xyz="1 0 0"/>
    <limit effort="20.0" lower="0.0" upper="2.618" velocity="1.0"/>
  </joint>
  <link name="toilet_lid">
    <visual>
      <origin rpy="0 0 0" xyz="0.0 -0.2 0.01"/>
      <geometry>
        <box size="0.36 0.44 0.02"/>
      </geometry>
      <material name="toilet_white"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.0 -0.2 0.01"/>
      <geometry>
        <box size="0.36 0.44 0.02"/>
      </geometry>
    </collision>
  </link>

  <!-- Toilet seat (revolute, separate from lid) -->
  <joint name="toilet_seat_joint" type="revolute">
    <origin rpy="0 0 0" xyz="0.0 0.2 0.42"/>
    <parent link="toilet"/>
    <child link="toilet_seat"/>
    <axis xyz="1 0 0"/>
    <limit effort="20.0" lower="0.0" upper="2.618" velocity="1.0"/>
  </joint>
  <link name="toilet_seat">
    <visual>
      <origin rpy="0 0 0" xyz="0.0 -0.18 0.005"/>
      <geometry>
        <box size="0.34 0.4 0.03"/>
      </geometry>
      <material name="toilet_white"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.0 -0.18 0.005"/>
      <geometry>
        <box size="0.34 0.4 0.03"/>
      </geometry>
    </collision>
  </link>

  <!-- Toilet flush button (prismatic) -->
  <joint name="toilet_flush_button_joint" type="prismatic">
    <origin rpy="0 0 0" xyz="0.0 0.27 0.78"/>
    <parent link="toilet"/>
    <child link="toilet_flush_button"/>
    <axis xyz="0 -1 0"/>
    <limit effort="10.0" lower="0.0" upper="0.015" velocity="0.1"/>
  </joint>
  <link name="toilet_flush_button">
    <visual>
      <geometry>
        <cylinder length="0.015" radius="0.03"/>
      </geometry>
      <material name="chrome"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.015" radius="0.03"/>
      </geometry>
    </collision>
  </link>

  <!-- ============================================================ -->
  <!-- WASHBASIN / SINK (mesh-less)                                 -->
  <!-- ============================================================ -->
  <joint name="washbasin_joint" type="fixed">
    <origin rpy="0 0 0" xyz="2.3 1.8 0.0"/>
    <parent link="bathroom_furniture_root"/>
    <child link="washbasin"/>
  </joint>
  <link name="washbasin">
    <!-- Pedestal -->
    <visual>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.42"/>
      <geometry>
        <cylinder length="0.84" radius="0.12"/>
      </geometry>
      <material name="toilet_white"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.42"/>
      <geometry>
        <cylinder length="0.84" radius="0.12"/>
      </geometry>
    </collision>
    <!-- Basin bowl -->
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.87"/>
      <geometry>
        <box size="0.58 0.46 0.18"/>
      </geometry>
    </collision>
  </link>

  <!-- Washbasin faucet (revolute) -->
  <joint name="washbasin_faucet_joint" type="revolute">
    <origin rpy="0 0 0" xyz="0.0 -0.18 1.0"/>
    <parent link="washbasin"/>
    <child link="washbasin_faucet"/>
    <axis xyz="0 0 1"/>
    <limit effort="100.0" lower="-1.5708" upper="1.5708" velocity="1.0"/>
  </joint>
  <link name="washbasin_faucet">
    <visual>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.08"/>
      <geometry>
        <cylinder length="0.16" radius="0.02"/>
      </geometry>
      <material name="chrome"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.08"/>
      <geometry>
        <cylinder length="0.16" radius="0.02"/>
      </geometry>
    </collision>
  </link>

  <!-- Washbasin hot handle -->
  <joint name="washbasin_hot_handle_joint" type="revolute">
    <origin rpy="0 0 0" xyz="0.1 -0.17 0.97"/>
    <parent link="washbasin"/>
    <child link="washbasin_hot_handle"/>
    <axis xyz="1 0 0"/>
    <limit effort="30.0" lower="0.0" upper="3.14" velocity="1.0"/>
  </joint>
  <link name="washbasin_hot_handle">
    <visual>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
      <material name="chrome"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
    </collision>
  </link>

  <!-- Washbasin cold handle -->
  <joint name="washbasin_cold_handle_joint" type="revolute">
    <origin rpy="0 0 0" xyz="-0.1 -0.17 0.97"/>
    <parent link="washbasin"/>
    <child link="washbasin_cold_handle"/>
    <axis xyz="1 0 0"/>
    <limit effort="30.0" lower="0.0" upper="3.14" velocity="1.0"/>
  </joint>
  <link name="washbasin_cold_handle">
    <visual>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
      <material name="chrome"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
    </collision>
  </link>

  <!-- ============================================================ -->
  <!-- BATHROOM CABINET / MEDICINE CABINET (mesh-less)              -->
  <!-- ============================================================ -->
  <joint name="medicine_cabinet_joint" type="fixed">
    <origin rpy="0 0 0" xyz="2.3 2.2 1.1"/>
    <parent link="bathroom_furniture_root"/>
    <child link="medicine_cabinet"/>
  </joint>
  <link name="medicine_cabinet">
    <visual>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.55 0.12 0.7"/>
      </geometry>
      <material name="toilet_white"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.55 0.12 0.7"/>
      </geometry>
    </collision>
  </link>

  <!-- Medicine cabinet door (revolute) -->
  <joint name="medicine_cabinet_door_joint" type="revolute">
    <origin rpy="0 0 0" xyz="-0.275 -0.06 0.0"/>
    <parent link="medicine_cabinet"/>
    <child link="medicine_cabinet_door"/>
    <axis xyz="0 0 1"/>
    <limit effort="50.0" lower="0.0" upper="1.5708" velocity="1.0"/>
  </joint>
  <link name="medicine_cabinet_door">
    <visual>
      <origin rpy="0 0 0" xyz="0.275 0.0 0.0"/>
      <geometry>
        <box size="0.55 0.015 0.7"/>
      </geometry>
      <material name="mirror_grey">
        <color rgba="0.85 0.9 0.92 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.275 0.0 0.0"/>
      <geometry>
        <box size="0.55 0.015 0.7"/>
      </geometry>
    </collision>
  </link>

  <joint name="medicine_cabinet_door_handle_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.52 0.025 0.0"/>
    <parent link="medicine_cabinet_door"/>
    <child link="medicine_cabinet_door_handle"/>
  </joint>
  <link name="medicine_cabinet_door_handle">
    <visual>
      <geometry>
        <cylinder length="0.08" radius="0.008"/>
      </geometry>
      <material name="chrome"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.08" radius="0.008"/>
      </geometry>
    </collision>
  </link>

  <!-- ============================================================ -->
  <!-- SHOWER (mesh-less, walls as thin boxes)                      -->
  <!-- ============================================================ -->
  <joint name="shower_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.5 2.8 0.0"/>
    <parent link="bathroom_furniture_root"/>
    <child link="shower"/>
  </joint>
  <link name="shower">
    <!-- Left wall -->
    <visual>
      <origin rpy="0 0 0" xyz="-0.45 0.0 1.1"/>
      <geometry>
        <box size="0.02 0.9 2.2"/>
      </geometry>
      <material name="glass_clear">
        <color rgba="0.85 0.92 0.95 0.4"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="-0.45 0.0 1.1"/>
      <geometry>
        <box size="0.02 0.9 2.2"/>
      </geometry>
    </collision>
    <!-- Back wall -->
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.45 1.1"/>
      <geometry>
        <box size="0.9 0.02 2.2"/>
      </geometry>
    </collision>
    <!-- Floor tray -->
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.04"/>
      <geometry>
        <box size="0.9 0.9 0.08"/>
      </geometry>
    </collision>
  </link>

  <!-- Shower door (revolute, glass) -->
  <joint name="shower_door_joint" type="revolute">
    <origin rpy="0 0 0" xyz="-0.45 -0.45 0.0"/>
    <parent link="shower"/>
    <child link="shower_door"/>
    <axis xyz="0 0 1"/>
    <limit effort="100.0" lower="0.0" upper="1.5708" velocity="1.0"/>
  </joint>
  <link name="shower_door">
    <visual>
      <origin rpy="0 0 0" xyz="0.0 0.45 1.1"/>
      <geometry>
        <box size="0.015 0.9 2.2"/>
      </geometry>
      <material name="glass_clear"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.45 1.1"/>
      <geometry>
        <box size="0.015 0.9 2.2"/>
      </geometry>
    </collision>
  </link>

  <joint name="shower_door_handle_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.025 0.12 1.1"/>
    <parent link="shower_door"/>
    <child link="shower_door_handle"/>
  </joint>
  <link name="shower_door_handle">
    <visual>
      <geometry>
        <cylinder length="0.12" radius="0.01"/>
      </geometry>
      <material name="chrome"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.12" radius="0.01"/>
      </geometry>
    </collision>
  </link>

  <!-- Shower head (fixed, mesh-less) -->
  <joint name="shower_head_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.0 0.42 2.0"/>
    <parent link="shower"/>
    <child link="shower_head"/>
  </joint>
  <link name="shower_head">
    <visual>
      <origin rpy="0 0.5236 0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <cylinder length="0.12" radius="0.06"/>
      </geometry>
      <material name="chrome"/>
    </visual>
    <collision>
      <origin rpy="0 0.5236 0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <cylinder length="0.12" radius="0.06"/>
      </geometry>
    </collision>
  </link>

  <!-- Shower temperature knob (revolute) -->
  <joint name="shower_temperature_knob_joint" type="revolute">
    <origin rpy="0 0 0" xyz="-0.44 0.3 1.2"/>
    <parent link="shower"/>
    <child link="shower_temperature_knob"/>
    <axis xyz="1 0 0"/>
    <limit effort="20.0" lower="-1.5708" upper="1.5708" velocity="1.0"/>
  </joint>
  <link name="shower_temperature_knob">
    <visual>
      <geometry>
        <cylinder length="0.04" radius="0.04"/>
      </geometry>
      <material name="chrome"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.04" radius="0.04"/>
      </geometry>
    </collision>
  </link>

  <!-- ============================================================ -->
  <!-- TOWEL RACK (mesh-less)                                       -->
  <!-- ============================================================ -->
  <joint name="towel_rack_joint" type="fixed">
    <origin rpy="0 0 0" xyz="1.8 0.07 1.1"/>
    <parent link="bathroom_furniture_root"/>
    <child link="towel_rack"/>
  </joint>
  <link name="towel_rack">
    <!-- Horizontal bar -->
    <visual>
      <origin rpy="1.5708 0 0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <cylinder length="0.6" radius="0.012"/>
      </geometry>
      <material name="chrome"/>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <cylinder length="0.6" radius="0.012"/>
      </geometry>
    </collision>
    <!-- Left bracket -->
    <collision>
      <origin rpy="0 0 0" xyz="0.0 -0.3 0.0"/>
      <geometry>
        <box size="0.06 0.04 0.06"/>
      </geometry>
    </collision>
    <!-- Right bracket -->
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.3 0.0"/>
      <geometry>
        <box size="0.06 0.04 0.06"/>
      </geometry>
    </collision>
  </link>

  <!-- ============================================================ -->
  <!-- LAUNDRY BASKET (mesh-less, cylinder, no moving parts)        -->
  <!-- ============================================================ -->
  <joint name="laundry_basket_joint" type="fixed">
    <origin rpy="0 0 0" xyz="1.5 2.9 0.0"/>
    <parent link="bathroom_furniture_root"/>
    <child link="laundry_basket"/>
  </joint>
  <link name="laundry_basket">
    <visual>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.3"/>
      <geometry>
        <cylinder length="0.6" radius="0.22"/>
      </geometry>
      <material name="basket_beige">
        <color rgba="0.8 0.72 0.55 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.3"/>
      <geometry>
        <cylinder length="0.6" radius="0.22"/>
      </geometry>
    </collision>
  </link>

  <!-- Laundry basket lid (revolute) -->
  <joint name="laundry_basket_lid_joint" type="revolute">
    <origin rpy="0 0 0" xyz="0.0 0.0 0.62"/>
    <parent link="laundry_basket"/>
    <child link="laundry_basket_lid"/>
    <axis xyz="1 0 0"/>
    <limit effort="10.0" lower="0.0" upper="2.618" velocity="1.5"/>
  </joint>
  <link name="laundry_basket_lid">
    <visual>
      <geometry>
        <cylinder length="0.02" radius="0.22"/>
      </geometry>
      <material name="basket_beige"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.02" radius="0.22"/>
      </geometry>
    </collision>
  </link>

  <!-- ============================================================ -->
  <!-- MIRROR (mesh-less, fixed to wall)                            -->
  <!-- ============================================================ -->
  <joint name="mirror_joint" type="fixed">
    <origin rpy="0 0 0" xyz="2.3 1.8 1.45"/>
    <parent link="bathroom_furniture_root"/>
    <child link="mirror"/>
  </joint>
  <link name="mirror">
    <visual>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.7 0.02 0.9"/>
      </geometry>
      <material name="mirror_grey"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <box size="0.7 0.02 0.9"/>
      </geometry>
    </collision>
  </link>

  <!-- ============================================================ -->
  <!-- TOILET PAPER HOLDER (mesh-less)                              -->
  <!-- ============================================================ -->
  <joint name="toilet_paper_holder_joint" type="fixed">
    <origin rpy="0 0 0" xyz="2.0 0.07 0.9"/>
    <parent link="bathroom_furniture_root"/>
    <child link="toilet_paper_holder"/>
  </joint>
  <link name="toilet_paper_holder">
    <!-- Arm -->
    <visual>
      <origin rpy="0 0 0" xyz="0.0 0.07 0.0"/>
      <geometry>
        <box size="0.025 0.14 0.025"/>
      </geometry>
      <material name="chrome"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.07 0.0"/>
      <geometry>
        <box size="0.025 0.14 0.025"/>
      </geometry>
    </collision>
    <!-- Roll bar -->
    <collision>
      <origin rpy="1.5708 0 0" xyz="0.0 0.13 0.0"/>
      <geometry>
        <cylinder length="0.14" radius="0.025"/>
      </geometry>
    </collision>
  </link>

  <!-- Toilet paper roll (mesh-less, fixed, separate link for recognition) -->
  <joint name="toilet_paper_roll_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.0 0.13 0.0"/>
    <parent link="toilet_paper_holder"/>
    <child link="toilet_paper_roll"/>
  </joint>
  <link name="toilet_paper_roll">
    <visual>
      <origin rpy="1.5708 0 0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <cylinder length="0.12" radius="0.055"/>
      </geometry>
      <material name="paper_white">
        <color rgba="1.0 1.0 0.98 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <cylinder length="0.12" radius="0.055"/>
      </geometry>
    </collision>
  </link>

</robot>
