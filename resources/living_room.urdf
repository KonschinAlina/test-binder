    <visual>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.75"/>
      <geometry>
        <box size="1.8 0.9 0.04"/>
      </geometry>
      <material name="light_wood">
        <color rgba="0.72 0.55 0.32 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.75"/>
