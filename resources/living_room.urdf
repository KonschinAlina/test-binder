  <!-- ============================================================ -->
  <!-- PLANT POT (mesh-less, sphere+cylinder)                       -->
  <!-- ============================================================ -->
  <joint name="plant_pot_joint" type="fixed">
    <origin rpy="0 0 0" xyz="5.0 3.5 0.0"/>
    <parent link="living_room_furniture_root"/>
    <child link="plant_pot"/>
  </joint>
  <link name="plant_pot">
    <!-- Pot body -->
    <visual>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.2"/>
