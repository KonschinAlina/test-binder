<?xml version="1.0" ?>
<!-- Test scene: Living Room (remixed) -->
<!-- Mix of real iai_apartment meshes (sofa, armchair, coffee_table, wardrobe) -->
<!-- plus mesh-less objects: tv_stand, television, bookshelf, plant, dining_table, dining_chair -->
<!-- Purpose: Testing parser with both mesh-based and primitive links -->
<robot name="living_room">

  <link name="apartment_root">
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </link>

  <joint name="living_room_base_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="apartment_root"/>
    <child link="living_room_furniture_root"/>
  </joint>
  <link name="living_room_furniture_root"/>

  <!-- ============================================================ -->
  <!-- SOFA (real mesh)                                             -->
  <!-- ============================================================ -->
  <joint name="sofa_joint" type="fixed">
    <origin rpy="0 0 0" xyz="2.5 0.6 0.0"/>
    <parent link="living_room_furniture_root"/>
    <child link="sofa"/>
  </joint>
  <link name="sofa">
    <visual>
      <geometry>
        <mesh filename="package://iai_apartment/meshes/visual/sofa.dae"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://iai_apartment/meshes/collision/sofa.obj"/>
      </geometry>
    </collision>
  </link>

  <!-- ============================================================ -->
  <!-- ARMCHAIR (real mesh, different position/orientation)         -->
  <!-- ============================================================ -->
  <joint name="armchair_joint" type="fixed">
    <origin rpy="0 0 -1.5708" xyz="4.5 1.8 0.0"/>
    <parent link="living_room_furniture_root"/>
    <child link="armchair"/>
  </joint>
  <link name="armchair">
    <visual>
      <geometry>
        <mesh filename="package://iai_apartment/meshes/visual/armchair.dae"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://iai_apartment/meshes/collision/armchair.obj"/>
      </geometry>
    </collision>
  </link>

  <!-- ============================================================ -->
  <!-- COFFEE TABLE (real mesh) + drawer                            -->
  <!-- ============================================================ -->
  <joint name="coffee_table_joint" type="fixed">
    <origin rpy="0 0 0" xyz="2.8 1.8 0.0"/>
    <parent link="living_room_furniture_root"/>
    <child link="coffee_table"/>
  </joint>
  <link name="coffee_table">
    <visual>
      <geometry>
        <mesh filename="package://iai_apartment/meshes/visual/coffee_table.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.39"/>
      <geometry>
        <box size="0.7 1.2 0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="coffee_table_drawer_joint" type="prismatic">
    <parent link="coffee_table"/>
    <child link="coffee_table_drawer"/>
    <axis xyz="-1 0 0"/>
    <limit effort="1000.0" lower="0.0" upper="0.5" velocity="0.5"/>
  </joint>
  <link name="coffee_table_drawer">
    <visual>
      <geometry>
        <mesh filename="package://iai_apartment/meshes/visual/coffee_table_drawer.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="-0.338806 0.0 0.21892"/>
      <geometry>
        <box size="0.0214 0.396 0.31569"/>
      </geometry>
    </collision>
  </link>

  <!-- ============================================================ -->
  <!-- BEDSIDE TABLE (real mesh, repurposed as end table)           -->
  <!-- ============================================================ -->
  <joint name="end_table_joint" type="fixed">
    <origin rpy="0 0 1.5708" xyz="4.5 0.6 0.0"/>
    <parent link="living_room_furniture_root"/>
    <child link="end_table"/>
  </joint>
  <link name="end_table">
    <visual>
      <geometry>
        <mesh filename="package://iai_apartment/meshes/visual/bedside_table.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.230"/>
      <geometry>
        <box size="0.312 0.312 0.460"/>
      </geometry>
    </collision>
  </link>

  <!-- ============================================================ -->
  <!-- TV STAND (mesh-less)                                         -->
  <!-- ============================================================ -->
  <joint name="tv_stand_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.2 1.8 0.0"/>
    <parent link="living_room_furniture_root"/>
    <child link="tv_stand"/>
  </joint>
  <link name="tv_stand">
    <!-- Main body -->
    <visual>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.25"/>
      <geometry>
        <box size="1.4 0.45 0.5"/>
      </geometry>
      <material name="dark_wood">
        <color rgba="0.25 0.15 0.08 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.25"/>
      <geometry>
        <box size="1.4 0.45 0.5"/>
      </geometry>
    </collision>
    <!-- Legs -->
    <collision>
      <origin rpy="0 0 0" xyz="-0.62 -0.18 0.04"/>
      <geometry>
        <box size="0.06 0.06 0.08"/>
      </geometry>
    </collision>
    <collision>
      <origin rpy="0 0 0" xyz="0.62 -0.18 0.04"/>
      <geometry>
        <box size="0.06 0.06 0.08"/>
      </geometry>
    </collision>
    <collision>
      <origin rpy="0 0 0" xyz="-0.62 0.18 0.04"/>
      <geometry>
        <box size="0.06 0.06 0.08"/>
      </geometry>
    </collision>
    <collision>
      <origin rpy="0 0 0" xyz="0.62 0.18 0.04"/>
      <geometry>
        <box size="0.06 0.06 0.08"/>
      </geometry>
    </collision>
  </link>

  <!-- TV stand left door (revolute) -->
  <joint name="tv_stand_door_left_joint" type="revolute">
    <origin rpy="0 0 0" xyz="-0.7 -0.225 0.25"/>
    <parent link="tv_stand"/>
    <child link="tv_stand_door_left"/>
    <axis xyz="0 0 1"/>
    <limit effort="100.0" lower="0.0" upper="1.5708" velocity="1.5708"/>
  </joint>
  <link name="tv_stand_door_left">
    <visual>
      <origin rpy="0 0 0" xyz="0.35 0.0 0.0"/>
      <geometry>
        <box size="0.68 0.015 0.48"/>
      </geometry>
      <material name="dark_wood"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.35 0.0 0.0"/>
      <geometry>
        <box size="0.68 0.015 0.48"/>
      </geometry>
    </collision>
  </link>

  <joint name="tv_stand_door_left_handle_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.65 0.02 0.0"/>
    <parent link="tv_stand_door_left"/>
    <child link="tv_stand_door_left_handle"/>
  </joint>
  <link name="tv_stand_door_left_handle">
    <visual>
      <geometry>
        <cylinder length="0.06" radius="0.008"/>
      </geometry>
      <material name="chrome_dark">
        <color rgba="0.3 0.3 0.3 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.06" radius="0.008"/>
      </geometry>
    </collision>
  </link>

  <!-- TV stand right door (revolute) -->
  <joint name="tv_stand_door_right_joint" type="revolute">
    <origin rpy="0 0 0" xyz="0.7 -0.225 0.25"/>
    <parent link="tv_stand"/>
    <child link="tv_stand_door_right"/>
    <axis xyz="0 0 -1"/>
    <limit effort="100.0" lower="0.0" upper="1.5708" velocity="1.5708"/>
  </joint>
  <link name="tv_stand_door_right">
    <visual>
      <origin rpy="0 0 0" xyz="-0.35 0.0 0.0"/>
      <geometry>
        <box size="0.68 0.015 0.48"/>
      </geometry>
      <material name="dark_wood"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="-0.35 0.0 0.0"/>
      <geometry>
        <box size="0.68 0.015 0.48"/>
      </geometry>
    </collision>
  </link>

  <joint name="tv_stand_door_right_handle_joint" type="fixed">
    <origin rpy="0 0 0" xyz="-0.65 0.02 0.0"/>
    <parent link="tv_stand_door_right"/>
    <child link="tv_stand_door_right_handle"/>
  </joint>
  <link name="tv_stand_door_right_handle">
    <visual>
      <geometry>
        <cylinder length="0.06" radius="0.008"/>
      </geometry>
      <material name="chrome_dark"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.06" radius="0.008"/>
      </geometry>
    </collision>
  </link>

  <!-- TV stand center drawer (prismatic) -->
  <joint name="tv_stand_center_drawer_joint" type="prismatic">
    <origin rpy="0 0 0" xyz="0.0 -0.225 0.44"/>
    <parent link="tv_stand"/>
    <child link="tv_stand_center_drawer"/>
    <axis xyz="0 -1 0"/>
    <limit effort="200.0" lower="0.0" upper="0.35" velocity="0.5"/>
  </joint>
  <link name="tv_stand_center_drawer">
    <visual>
      <origin rpy="0 0 0" xyz="0.0 -0.17 0.0"/>
      <geometry>
        <box size="0.38 0.35 0.08"/>
      </geometry>
      <material name="dark_wood"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.0 -0.17 0.0"/>
      <geometry>
        <box size="0.38 0.35 0.08"/>
      </geometry>
    </collision>
  </link>

  <joint name="tv_stand_center_drawer_handle_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.0 -0.35 0.0"/>
    <parent link="tv_stand_center_drawer"/>
    <child link="tv_stand_center_drawer_handle"/>
  </joint>
  <link name="tv_stand_center_drawer_handle">
    <visual>
      <origin rpy="1.5708 0 0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <cylinder length="0.15" radius="0.007"/>
      </geometry>
      <material name="chrome_dark"/>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0.0 0.0 0.0"/>
      <geometry>
        <cylinder length="0.15" radius="0.007"/>
      </geometry>
    </collision>
  </link>

  <!-- ============================================================ -->
  <!-- TELEVISION (mesh-less)                                       -->
  <!-- ============================================================ -->
  <joint name="television_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.0 0.0 0.52"/>
    <parent link="tv_stand"/>
    <child link="television"/>
  </joint>
  <link name="television">
    <!-- Screen bezel -->
    <visual>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.35"/>
      <geometry>
        <box size="1.2 0.07 0.7"/>
      </geometry>
      <material name="tv_dark">
        <color rgba="0.08 0.08 0.08 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0.0 0.0 0.35"/>
      <geometry>
        <box size="1.2 0.07 0.7"/>
      </geometry>
    </collision>
    <!-- Screen surface -->
    <collision>
      <origin rpy="0 0 0" xyz="0.0 -0.038 0.35"/>
      <geometry>
        <box size="1.16 0.005 0.66"/>
      </geometry>
    </collision>
  </link>

  <!-- ============================================================ -->
  <!-- WARDROBE (real mesh, reused from apartment)                  -->
  <!-- ============================================================ -->
  <joint name="wardrobe_joint" type="fixed">
    <origin rpy="0 0 0" xyz="5.2 0.5 0.0"/>
    <parent link="living_room_furniture_root"/>
