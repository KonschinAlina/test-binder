  <!-- ============================================================ -->
  <!-- DINING TABLE (mesh-less)                                     -->
  <!-- ============================================================ -->
  <joint name="dining_table_joint" type="fixed">
    <origin rpy="0 0 0" xyz="2.5 4.5 0.0"/>
    <parent link="living_room_furniture_root"/>
    <child link="dining_table"/>
  </joint>
  <link name="dining_table">
